# Local dev: support form POST is proxied to dev Firebase Hosting (see web/vite.config.ts).
# Production: `/api/support` is served by the same host via a Hosting rewrite to Cloud Functions.

# Google Analytics 4 — Web data stream Measurement ID (see GA4 Admin → Data streams).
# Optional for local dev. Production builds load .env.production automatically.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# AppsFlyer OneLink template (Smart Script). Defaults to medidojo.onelink if unset.
# VITE_APPSFLYER_ONELINK_TEMPLATE_URL=https://medidojo.onelink.me/miw9

# AppsFlyer OneLink Smart Banner V2 — Web key from AppsFlyer → Website workplace (UUID in snippet).
# Leave unset to disable the banner snippet (e.g. local dev).
# VITE_APPSFLYER_BANNER_WEB_KEY=89855429-509d-4f9f-b48d-2f16b5c695dc
