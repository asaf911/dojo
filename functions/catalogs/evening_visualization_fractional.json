        "Asaf": "modules/evening_visualization_fractional/asaf/EV_KM_REM_300_RETURN_TO_REWIND_ASAF.mp3",
        "Dan": "modules/evening_visualization_fractional/asaf/EV_KM_REM_300_RETURN_TO_REWIND_ASAF.mp3"
