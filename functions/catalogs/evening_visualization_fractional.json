      "durationSec": 4
    },
    {
      "clipId": "EVK_C008",
      "role": "reminder",
      "order": 310,
      "priority": "p2",
      "reminderPriority": "secondary",
      "contentTrack": "Retrospection",
      "text": "When something brings up strong emotion, rewind and stay with it a little longer.",
      "voices": {
        "Asaf": "modules/evening_visualization_fractional/asaf/EV_KM_REM_310_PROCESS_EMOTIONS_ASAF.mp3",
        "Dan": "modules/evening_visualization_fractional/asaf/EV_KM_REM_310_PROCESS_EMOTIONS_ASAF.mp3"
      },
      "durationSec": 5
    },
    {
      "clipId": "EVK_C009",
      "role": "reminder",
      "order": 320,
      "priority": "p2",
      "contentTrack": "Retrospection",
      "text": "Continue observing what appears in your mind and heart.",
      "voices": {
        "Asaf": "modules/evening_visualization_fractional/asaf/EV_KM_REM_320_OBSERVE_WITHOUT_ANALYZING_ASAF.mp3",
