{
  "version": "4.1.0",
  "last_updated": "2026-02-11",
  "description": "AI meditation composition rules - 4-phase blueprint with finite focus modules (IM: I AM Mantra, NF: Nostril Focus)",

  "priority_detection": {
    "description": "When user explicitly requests a specific exercise, give it 50% of session time",
    "rules": {
      "body_scan": {
        "keywords": ["body scan", "bodyscan", "body awareness"],
        "target_module": "BS",
        "allocation": "50% of session duration (capped at BS10)"
      },
      "breathing": {
        "keywords": ["breath", "breathing", "breathwork"],
        "target_module": "PB",
        "allocation": "50% of session duration (capped at PB5)"
      },
      "i_am_mantra": {
        "keywords": ["mantra", "chant", "chanting", "i am", "affirmation"],
        "target_module": "IM",
        "allocation": "50% of session duration (capped at IM10)"
      },
      "nostril_focus": {
        "keywords": ["nostril", "nostril focus", "nadi shodhana", "alternate nostril"],
        "target_module": "NF",
        "allocation": "50% of session duration (capped at NF10)"
      },
      "visualization": {
        "keywords": ["visualization", "vision", "intention", "intentions"],
        "target_module": "VC",
        "allocation": "priority placement in visualization phase"
      },
      "retrospection": {
        "keywords": ["retrospection", "reflection", "gratitude"],
        "target_module": "RT",
        "allocation": "priority placement in visualization phase"
      }
    },
    "when_priority_detected": {
      "action": "Give priority exercise 50% of total session time",
      "other_modules": "Reduce to minimum (1m each)",
      "example_10m_bodyscan": "SI@start, PB1@1, BS5@2, IM2@7, GB@end"
    }
  },

  "module_type_classifications": {
    "finite_exercise": {
      "description": "Full-duration guided audio. The audio file IS the exercise.",
      "time_allocation": "exact duration of the module",
      "behavior": "Occupies its full duration in the session timeline. No additional quiet time needed.",
      "modules": ["SI", "BS1", "BS2", "BS3", "BS4", "BS5", "BS6", "BS7", "BS8", "BS9", "BS10", "PB1", "PB2", "PB3", "PB4", "PB5", "IM2", "IM3", "IM4", "IM5", "IM6", "IM7", "IM8", "IM9", "IM10", "NF1", "NF2", "NF3", "NF4", "NF5", "NF6", "NF7", "NF8", "NF9", "NF10"]
    },
    "trigger_cue": {
      "description": "Short audio trigger that instructs user to BEGIN a practice. User continues in silence.",
      "time_allocation": "Cue audio + remaining phase time as quiet practice",
      "behavior": "After audio plays, user continues the practice silently until next module.",
      "audio_duration_note": "Actual duration loaded from cues_models.json via CueManager",
      "modules": ["OH", "VC", "RT"]
    },
    "instant_cue": {
      "description": "Brief sound marker with no time allocation needed.",
      "time_allocation": "0 minutes",
      "behavior": "Instant audio marker, does not occupy timeline space.",
      "modules": ["GB"]
    }
  },

  "special_modules": {
    "SI": {
      "position": "start",
      "required": true,
      "duration": 1,
      "skip_keywords": ["no settle in", "skip settle in", "without settle in", "no settling", "skip settling", "no SI"]
    },
    "GB": {
      "position": "end",
      "skip_for": ["sleep", "bedtime", "night", "fall asleep", "drift off", "slumber"]
    }
  },

  "short_session_rules": {
    "description": "Rules for sessions 1-6 minutes. Simpler structure than 4-phase.",
    "rules": {
      "1min": {
        "structure": "SI + GB",
        "cues": ["SI@start", "GB@end"],
        "notes": "Settle in only"
      },
      "2-3min": {
        "structure": "SI + ONE relaxation (PB or BS) + GB",
        "cues_2m": ["SI@start", "PB1@1 or BS1@1", "GB@end"],
        "cues_3m": ["SI@start", "PB2@1 or BS2@1", "GB@end"],
        "notes": "Choose PB or BS based on prompt, not both"
      },
      "4min": {
        "structure": "SI + PB + BS + GB (no focus module)",
        "cues": ["SI@start", "PB1@1", "BS2@2", "GB@end"],
        "notes": "Both breathing and body scan, but no focus module"
      },
      "5-6min": {
        "structure": "SI + PB + BS + focus + GB",
        "cues_5m": ["SI@start", "PB1@1", "BS1@2", "IM2 or NF2@3", "GB@end"],
        "cues_6m": ["SI@start", "PB1@1", "BS2@2", "IM2 or NF2@4", "GB@end"],
        "focus_selection": {
          "default": "IM2 or NF2 (random)",
          "nostril": "NF2",
          "mantra": "IM2",
          "sleep": "OH"
        },
        "notes": "ONE focus module (IM2 or NF2 randomly, OH for sleep, explicit request overrides)"
      }
    },
    "gb_rule": "GB at end for ALL sessions (short and long) EXCEPT sleep sessions"
  },

  "composition_algorithm": {
    "description": "4-phase blueprint for sessions > 6 minutes. Fills 100% of session time.",
    "target_fill_percentage": 100,
    "phases": {
      "settle_in": {
        "range": "0% to ~10%",
        "duration": 1,
        "modules": ["SI"],
        "required": true
      },
      "relaxation": {
        "range": "~10% to 50%",
        "modules": ["PB", "BS"],
        "split": { "breathing": 0.40, "body_scan": 0.60 },
        "purpose": "Physical relaxation and grounding"
      },
      "focus": {
        "range": "50% to 75%",
        "modules": ["IM", "NF", "OH"],
        "purpose": "Guided focus practice (I AM mantra or nostril focus) or emotional focus",
        "preferred": "IM or NF",
        "note": "IM and NF are finite exercises (1-10m guided audio). Use only ONE per session unless user explicitly requests both. OH remains a trigger cue for sleep/emotional sessions."
      },
      "visualization": {
        "range": "75% to 100%",
        "modules": ["VC", "RT"],
        "purpose": "Intention, vision, or reflection practice",
        "preferred_by_time": { "morning": "VC", "evening": "RT", "default": "VC" },
        "note": "OH is NOT a visualization cue - use only VC or RT"
      },
      "closing": {
        "modules": ["GB"],
        "skip_for": ["sleep", "bedtime", "night"]
      }
    },
    "steps": [
      {
        "step": 1,
        "action": "Add SI at start",
        "details": "Always start with Settling In (SI) at trigger 'start'. Duration: 1 minute.",
        "time_used": 1
      },
      {
        "step": 2,
        "action": "Calculate phase boundaries",
        "details": "relaxation_end = floor(duration * 0.5), focus_end = floor(duration * 0.75)"
      },
      {
        "step": 3,
        "action": "Add breathing (PB) in relaxation phase",
        "details": "PB gets 40% of relaxation time. relaxation_time = relaxation_end - 1. PB_duration = round(relaxation_time * 0.4), capped at 5.",
        "placement": "minute 1"
      },
      {
        "step": 4,
        "action": "Add body scan (BS) in relaxation phase",
        "details": "BS gets remaining relaxation time. BS_duration = relaxation_end - 1 - PB_duration, capped at 10.",
        "placement": "minute (1 + PB_duration)"
      },
      {
        "step": 5,
        "action": "Add focus module (IM or NF) in focus phase",
        "details": "Select ONE focus module: IM (I AM Mantra) or NF (Nostril Focus), randomly unless user requested a specific one. Duration = focus_end - relaxation_end, capped at 10, min 1 (NF) or 2 (IM). Both are finite exercises (guided audio fills exact duration).",
        "placement": "minute relaxation_end"
      },
      {
        "step": 6,
        "action": "Add visualization trigger cue",
        "details": "Add VC (morning) or RT (evening) at focus_end. Audio plays for 2 min, user practices silently until session end.",
        "placement": "minute focus_end"
      },
      {
        "step": 7,
        "action": "Add GB at end",
        "details": "Add Gentle Bell at trigger 'end' unless this is a sleep meditation.",
        "placement": "trigger 'end'"
      }
    ]
  },

