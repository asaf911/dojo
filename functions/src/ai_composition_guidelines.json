  "strict_rules": [
    {
      "id": "si_at_start",
      "rule": "SI (Settling In) must be at trigger 'start'",
      "priority": 100
    },
    {
      "id": "gb_at_end",
      "rule": "GB (Gentle Bell) must be at trigger 'end' for all non-sleep meditations",
      "priority": 90
    },
    {
      "id": "no_overlap",
      "rule": "Modules must NOT overlap - each module's end time must be <= next module's start time",
      "priority": 100
    },
    {
      "id": "fill_100_percent",
      "rule": "Modules must fill 100% of the session duration using the 4-phase structure",
      "priority": 100
    },
    {
      "id": "focus_and_viz",
      "rule": "Sessions > 6 min must have one finite focus module (IM or NF) and one visualization trigger cue (VC/RT)",
      "priority": 95
    },
    {
      "id": "valid_triggers",
      "rule": "Trigger values must be 'start', 'end', or a valid minute number (string)",
      "priority": 100
    },
    {
      "id": "always_bg_and_bb",
      "rule": "Always include a background sound and binaural beat unless user explicitly asks for silence",
      "priority": 90
    }
  ],

